  "license": "Apache-2.0",
  "homepage": "https://github.com/vdssinha/harbor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vdssinha/harbor.git"
  },
  "bin": {
    "harbor-gateway": "./dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "gateway",
