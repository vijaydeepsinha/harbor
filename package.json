  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@modelcontextprotocol/node": "^2.0.0-beta.4",
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "axios": "^1.7.9",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "isolated-vm": "^5.0.1",
    "jose": "^5.10.0",
    "js-yaml": "^4.3.0",
    "memjs": "^1.3.2",
    "pino": "^9.6.0",
    "uuid": "^11.1.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/memjs": "^1.3.3",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "pino-caller": "^4.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.7"
  },
  "scripts": {
    "build": "tsc",
