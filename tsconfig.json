{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "core/**/*",
    "runtime/**/*",
    "tools/**/*",
    "spi/**/*",
    "adapters/**/*",
    "wiring/**/*",
    "index.ts"
  ],
  "exclude": ["node_modules", "dist", "tests", "examples"]
}
